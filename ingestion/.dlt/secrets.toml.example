# Copy to secrets.toml and fill in. secrets.toml is gitignored.
# Postgres destination credentials.
# https://dlthub.com/docs/dlt-ecosystem/destinations/postgres

[destination.postgres.credentials]
database = "maplestory"
username = "postgres"
password = ""            # fill in
host = "localhost"
port = 5432

# Source API credentials (example)
# [sources.maplestory]
# api_key = ""
